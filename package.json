{
  "name": "@pictify/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Pictify - Generate images, GIFs, and PDFs with AI agents",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "pictify-mcp": "./build/index.js",
    "pictify-mcp-http": "./build/http.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js build/http.js",
    "start:http": "node build/http.js",
    "prepublishOnly": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "pictify",
    "image-generation",
    "ai",
    "claude",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "express": "^4.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
